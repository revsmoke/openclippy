{
  "name": "openclippy",
  "version": "0.1.0",
  "description": "Autonomous AI work agent for Microsoft 365",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "openclippy": "./openclippy.mjs"
  },
  "files": [
    "dist",
    "openclippy.mjs"
  ],
  "keywords": [
    "microsoft-365",
    "graph-api",
    "ai-agent",
    "outlook",
    "teams",
    "onedrive",
    "calendar",
    "todo",
    "claude",
    "autonomous-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revsmoke/openclippy.git"
  },
  "homepage": "https://github.com/revsmoke/openclippy#readme",
  "bugs": {
    "url": "https://github.com/revsmoke/openclippy/issues"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@azure/msal-node": "^2.16.0",
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.14",
    "tsdown": "^0.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "rolldown"
    ]
  }
}